{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "buyer/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "seller/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "login/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "admin/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "session/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "t&c/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "routes": [
      {
        "src": "/",
        "dest": "/login/login.php"
      },
      {
        "src": "/(.*)",
        "dest": "/$1"
      }
    ],
    "env": {
      "DB_TYPE": "pgsql"
    }
  }
}